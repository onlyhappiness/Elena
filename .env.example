# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (for embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://elena:elena@localhost:5432/elena

# fal.ai
FAL_KEY=your_fal_api_key_here

# App Settings
# development → debug 모드 (상세 로그)
# production  → 프로덕션 모드 (간결한 로그, 스택 트레이스 숨김)
APP_ENV=development
